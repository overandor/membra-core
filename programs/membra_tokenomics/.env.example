# MEMBRA Tokenomics Program Configuration
# Copy to .env and fill in values before deployment

# Solana Cluster (localnet, devnet, mainnet)
SOLANA_CLUSTER=devnet

# Program ID (replace after anchor deploy)
TOKENOMICS_PROGRAM_ID=Tok3nom1csMEMBRAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Sale Authority Keypair Path
AUTHORITY_KEYPAIR=~/.config/solana/id.json

# Treasury Wallet (receives 80% of contributions)
TREASURY_WALLET=

# Protocol Wallet (receives 10% of contributions)
PROTOCOL_WALLET=

# Validator Pool Wallet (receives 5% of contributions)
VALIDATOR_POOL_WALLET=

# Sale Parameters
BASE_PRICE_LAMPORTS=100000
SLOPE_BPS=100
MAX_BONUS_BPS=2000
SALE_DURATION_SEC=3600
EARLY_REWARD_CAP_LAMPORTS=10000000000
MAX_REBATE_PER_BUYER_LAMPORTS=1000000000
REBATE_RATE_BPS=500
HARD_CAP_LAMPORTS=100000000000
MIN_CONTRIBUTION_LAMPORTS=10000000
